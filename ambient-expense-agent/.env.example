# ==============================================================================
# Google Cloud Platform (GCP) Authentication & Configuration (Default)
# ==============================================================================
# Set this to use Google Cloud / Vertex AI (Agent Runtime)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-east1
GOOGLE_GENAI_USE_VERTEXAI=True

# To authenticate local development with GCP:
# Run: gcloud auth application-default login

# ==============================================================================
# Google AI Studio API Key Authentication (Optional)
# ==============================================================================
# Set this if you want to use Google AI Studio directly instead of Vertex AI.
# Get your API key from: https://aistudio.google.com/
# GEMINI_API_KEY=your-api-key-here
