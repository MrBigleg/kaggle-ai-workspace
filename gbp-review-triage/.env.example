# ==============================================================================
# Google Business Profile Review Triage Agent - Local Environment Configuration
# ==============================================================================

# OPTION 1: Google Cloud (Vertex AI) - Active Option
# --------------------------------------------------
# To authenticate local development with your Google Cloud project:
# 1. Run the following command in your terminal:
#    gcloud auth application-default login
# 2. Set the variables below for your GCP project:

GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-east1"
GOOGLE_GENAI_USE_VERTEXAI="True"


# OPTION 2: Google AI Studio (Gemini Developer API)
# --------------------------------------------------
# To use Gemini Developer API directly without Google Cloud:
# 1. Obtain an API key from Google AI Studio: https://aistudio.google.com/
# 2. Uncomment and set the variables below:

# GEMINI_API_KEY="your_ai_studio_api_key_here"
# GOOGLE_GENAI_USE_VERTEXAI="False"
